# Copy this file to .env.local and fill in the values.
# .env.local is gitignored so your secrets never land in source control.

# --- Stripe ---
# From https://dashboard.stripe.com/apikeys (use test keys until you're ready to go live)
STRIPE_SECRET_KEY=sk_test_xxx

# Price ID for Daily Fibre. Create a product in Stripe -> Products, add a one-time GBP price,
# then paste its `price_...` id here.
STRIPE_PRICE_ID=price_xxx

# Signing secret for the Stripe webhook at /api/stripe/webhook.
# Dashboard: Developers -> Webhooks -> add endpoint -> copy the `whsec_...` value.
# For local dev with `stripe listen --forward-to localhost:3000/api/stripe/webhook`,
# the CLI prints a whsec_... on startup — paste it here.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Meta Conversions API ---
# System user access token for the pixel.
# Events Manager -> your pixel -> Settings -> Conversions API -> Generate access token.
# Treat like a password.
META_CAPI_ACCESS_TOKEN=

# Optional. While you're testing, Events Manager gives you a test code
# (Test Events tab -> TEST#####). Paste it here to see CAPI events land in
# the Test Events view. Remove for live traffic so events count as real.
META_CAPI_TEST_EVENT_CODE=

# --- Site ---
# Used to build absolute success/cancel URLs for Stripe Checkout.
# Local: http://localhost:3000
# Prod:  https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
